# Padlet API 키 (유료 계정 2개)
PADLET_API_KEY_1=
PADLET_API_KEY_2=

# 교사 로그인 비밀번호
ADMIN_PASSWORD=

# 세션 암호화 키 (16자 이상 랜덤 문자열)
SESSION_SECRET=

# Firebase 서비스 계정 JSON (한 줄로 붙여넣기)
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성 > JSON 다운로드
# 파일을 열어 {"type":"service_account","project_id":"...", ...} 전체를 한 줄로 복사
# 주의: 프로젝트 ID(UUID)만 넣으면 JSON 파싱 오류가 납니다
FIREBASE_SERVICE_ACCOUNT_JSON=
